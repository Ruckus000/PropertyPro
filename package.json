{
  "name": "propertypro",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "setup": "./scripts/setup.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:verify": "tsx scripts/verify-seed-evidence.ts",
    "plan:verify:phase2": "tsx scripts/verify-phase2-plan-status.ts",
    "plan:verify:phase3": "tsx scripts/verify-phase3-plan-status.ts",
    "plan:verify:phase4": "tsx scripts/verify-phase4-plan-status.ts",
    "perf:check": "tsx scripts/perf-check.ts",
    "lint:docs": "tsx scripts/lint-documentation.ts",
    "test:integration:preflight": "pnpm --filter @propertypro/db db:migrate && pnpm seed:verify && pnpm --filter @propertypro/db test:integration && pnpm exec vitest run --config apps/web/vitest.integration.config.ts",
    "test:watch": "vitest",
    "guard:db-access": "tsx scripts/verify-scoped-db-access.ts",
    "lint": "turbo run lint && pnpm guard:db-access",
    "clean": "turbo run clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@propertypro/db": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "postgres": "^3.4.8",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
