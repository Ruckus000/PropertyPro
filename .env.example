# =============================================================================
# PropertyPro Florida — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SUPABASE
#    Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Project Settings → Database)
# Pooled connection (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used ONLY for migrations
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# 2. STRIPE
#    Get these from: Stripe Dashboard → Developers → API keys
#    Webhook secret: Developers → Webhooks → your endpoint → Signing secret
#    (Can defer to Phase 2)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — one per plan (Stripe Dashboard → Products → Price ID)
# Env key format: STRIPE_PRICE_<PLAN_ID_UPPERCASED> (see apps/web/src/lib/services/stripe-service.ts)
# Plan IDs: compliance_basic, compliance_plus_mobile, full_platform, apartment_operations
STRIPE_PRICE_COMPLIANCE_BASIC=price_...
STRIPE_PRICE_COMPLIANCE_PLUS_MOBILE=price_...
STRIPE_PRICE_FULL_PLATFORM=price_...
STRIPE_PRICE_APARTMENT_OPERATIONS=price_...
# Stripe Connect OAuth (Standard accounts — Phase 1A)
# Get from: Stripe Dashboard → Settings → Connect → Platform settings → Client ID
STRIPE_CONNECT_CLIENT_ID=ca_...

# -----------------------------------------------------------------------------
# 3. RESEND
#    Get these from: Resend Dashboard → API Keys
#    (Can defer to Phase 1)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# 4. SENTRY
#    Get these from: Sentry → Project Settings → Client Keys (DSN)
#    Auth token: Sentry → Settings → Auth Tokens
# -----------------------------------------------------------------------------
# Client-side DSN (exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN
SENTRY_DSN=
# Source map upload token (only needed for production builds)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# 5. UPSTASH REDIS
#    Get these from: Upstash Console → Your Database → REST API
#    (Can defer to Phase 2)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# -----------------------------------------------------------------------------
# 6. APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin app origin for CSP frame-ancestors when preview iframes are used.
# Default: http://localhost:3001 (dev) / https://admin.propertyprofl.com (prod)
# Override if admin is hosted at a custom domain.
ADMIN_ORIGIN=
# Cookie domain for cross-subdomain session sharing.
# Set to .propertyprofl.com in production. Leave empty for localhost dev.
# Do NOT set on Vercel preview deploys (cookies should scope to preview hostname).
NEXT_PUBLIC_COOKIE_DOMAIN=
NODE_ENV=development

# -----------------------------------------------------------------------------
# 7. INTERNAL CRON AUTH
# -----------------------------------------------------------------------------
# GitHub Actions cron job base URL (production deployment URL)
# Used by: .github/workflows/notification-digest-cron.yml
# This should be your Vercel production URL (e.g., https://property-pro-xyz.vercel.app)
# NOTE: This is configured as a GitHub repository secret, not in this .env file
DIGEST_CRON_BASE_URL=https://your-production-url.vercel.app

# Shared bearer secret used by scheduler calls to:
# POST /api/v1/internal/notification-digests/process
NOTIFICATION_DIGEST_CRON_SECRET=change-me
# POST /api/v1/internal/payment-reminders
PAYMENT_REMINDERS_CRON_SECRET=change-me
DEMO_EXPIRY_CRON_SECRET=change-me
# POST /api/v1/internal/assessment-overdue
# POST /api/v1/internal/late-fee-processor
# POST /api/v1/internal/generate-assessments
ASSESSMENT_CRON_SECRET=change-me
# POST /api/v1/internal/provision (manual provisioning retry for platform admin)
PROVISIONING_RETRY_SECRET=change-me
# POST /api/v1/internal/assessment-overdue, /late-fee-processor, /generate-assessments
ASSESSMENT_CRON_SECRET=change-me
COMPLIANCE_CRON_SECRET=change-me
VISITOR_AUTO_CHECKOUT_CRON_SECRET=change-me

# -----------------------------------------------------------------------------
# 8. DEMO SEED DATA
# -----------------------------------------------------------------------------
# AES-256-GCM key for demo token-secret encryption at rest.
# Generate with: openssl rand -hex 32
DEMO_TOKEN_ENCRYPTION_KEY_HEX=

# Used by `pnpm seed:demo` to create/update demo authentication users.
# Demo emails are defined in scripts/config/demo-data.ts.
DEMO_DEFAULT_PASSWORD=DemoPass123!

# Dev auto-login shortcuts (development only, ignored in production)
# Usage: GET /dev/login?as=owner
# Valid roles: owner, tenant, board_president, board_member, cam, pm_admin, site_manager
DEV_LOGIN_OWNER_EMAIL=owner.one@sunset.local
DEV_LOGIN_TENANT_EMAIL=tenant.one@sunset.local
DEV_LOGIN_BOARD_PRESIDENT_EMAIL=board.president@sunset.local
DEV_LOGIN_BOARD_MEMBER_EMAIL=board.member@sunset.local
DEV_LOGIN_CAM_EMAIL=cam.one@sunset.local
DEV_LOGIN_PM_ADMIN_EMAIL=pm.admin@sunset.local
DEV_LOGIN_SITE_MANAGER_EMAIL=site.manager@sunsetridge.local

# -----------------------------------------------------------------------------
# 9. TWILIO (Phase 1B — Emergency SMS Notifications)
#    Get these from: Twilio Console → Account Info (SID + Auth Token)
#    Messaging Service: Twilio Console → Messaging → Services
#    Verify Service: Twilio Console → Verify → Services
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_VERIFY_SERVICE_SID=VA...

# -----------------------------------------------------------------------------
# 10. OAUTH TOKEN ENCRYPTION (WS-70)
# -----------------------------------------------------------------------------
# AES-256-GCM key for calendar/accounting OAuth tokens.
# Required for WS-70 connector routes in non-test environments.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# 11. SUPPORT SESSION JWT (Support Access)
# -----------------------------------------------------------------------------
# HMAC secret for signing support impersonation JWTs (min 32 chars).
# Generate with: openssl rand -base64 32
SUPPORT_SESSION_JWT_SECRET=
