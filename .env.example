# =============================================================================
# PropertyPro Florida — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SUPABASE
#    Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Project Settings → Database)
# Pooled connection (port 6543) — used by the app at runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used ONLY for migrations
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# 2. STRIPE
#    Get these from: Stripe Dashboard → Developers → API keys
#    Webhook secret: Developers → Webhooks → your endpoint → Signing secret
#    (Can defer to Phase 2)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# 3. RESEND
#    Get these from: Resend Dashboard → API Keys
#    (Can defer to Phase 1)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# 4. SENTRY
#    Get these from: Sentry → Project Settings → Client Keys (DSN)
#    Auth token: Sentry → Settings → Auth Tokens
# -----------------------------------------------------------------------------
# Client-side DSN (exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN
SENTRY_DSN=
# Source map upload token (only needed for production builds)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# 5. UPSTASH REDIS
#    Get these from: Upstash Console → Your Database → REST API
#    (Can defer to Phase 2)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# -----------------------------------------------------------------------------
# 6. APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# 7. DEMO SEED DATA
# -----------------------------------------------------------------------------
# Used by `pnpm seed:demo` to create/update demo authentication users.
# Demo emails are defined in scripts/config/demo-data.ts.
DEMO_DEFAULT_PASSWORD=DemoPass123!
