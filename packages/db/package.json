{
  "name": "@propertypro/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./supabase/client": {
      "types": "./src/supabase/client.ts",
      "import": "./src/supabase/client.ts",
      "default": "./src/supabase/client.ts"
    },
    "./supabase/server": {
      "types": "./src/supabase/server.ts",
      "import": "./src/supabase/server.ts",
      "default": "./src/supabase/server.ts"
    },
    "./supabase/admin": {
      "types": "./src/supabase/admin.ts",
      "import": "./src/supabase/admin.ts",
      "default": "./src/supabase/admin.ts"
    },
    "./supabase/middleware": {
      "types": "./src/supabase/middleware.ts",
      "import": "./src/supabase/middleware.ts",
      "default": "./src/supabase/middleware.ts"
    },
    "./supabase/cookie-config": {
      "types": "./src/supabase/cookie-config.ts",
      "import": "./src/supabase/cookie-config.ts",
      "default": "./src/supabase/cookie-config.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "import": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./filters": {
      "types": "./src/filters.ts",
      "import": "./src/filters.ts",
      "default": "./src/filters.ts"
    },
    "./unsafe": {
      "types": "./src/unsafe.ts",
      "import": "./src/unsafe.ts",
      "default": "./src/unsafe.ts"
    },
    "./seed/seed-community": {
      "types": "./src/seed/seed-community.ts",
      "import": "./src/seed/seed-community.ts",
      "default": "./src/seed/seed-community.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "next": "^15.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@propertypro/shared": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  }
}
