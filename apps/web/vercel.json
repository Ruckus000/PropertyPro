{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter '@propertypro/shared' --filter '@propertypro/db' --filter '@propertypro/email' --filter '@propertypro/ui' build && pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/payment-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/internal/assessment-overdue",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/v1/internal/late-fee-processor",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/v1/internal/generate-assessments",
      "schedule": "0 5 1 * *"
    },
    {
      "path": "/api/v1/internal/assessment-due-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/v1/internal/expire-demos",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/internal/account-lifecycle",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/v1/internal/compliance-alerts",
      "schedule": "30 7 * * *"
    }
  ]
}
