{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@propertypro/ui": [
        "../../packages/ui/src"
      ],
      "@propertypro/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@propertypro/db": [
        "../../packages/db/src"
      ],
      "@propertypro/db/supabase/client": [
        "../../packages/db/src/supabase/client.ts"
      ],
      "@propertypro/db/supabase/server": [
        "../../packages/db/src/supabase/server.ts"
      ],
      "@propertypro/db/supabase/admin": [
        "../../packages/db/src/supabase/admin.ts"
      ],
      "@propertypro/db/supabase/middleware": [
        "../../packages/db/src/supabase/middleware.ts"
      ],
      "@propertypro/db/filters": [
        "../../packages/db/src/filters.ts"
      ],
      "@propertypro/db/unsafe": [
        "../../packages/db/src/unsafe.ts"
      ],
      "@propertypro/shared": [
        "../../packages/shared/src"
      ],
      "@propertypro/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@propertypro/theme": [
        "../../packages/theme/src"
      ],
      "@propertypro/tokens": [
        "../../packages/tokens/src"
      ],
      "@propertypro/tokens/*": [
        "../../packages/tokens/src/*"
      ]
    },
    "incremental": true
  },
  "include": [
    "*.mjs",
    "*.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
