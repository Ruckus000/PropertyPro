{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@propertypro/ui": [
        "../../packages/ui/src"
      ],
      "@propertypro/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@propertypro/db": [
        "../../packages/db/src"
      ],
      "@propertypro/db/*": [
        "../../packages/db/src/*"
      ],
      "@propertypro/shared": [
        "../../packages/shared/src"
      ],
      "@propertypro/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "incremental": true
  },
  "include": [
    "*.mjs",
    "*.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
